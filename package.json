{
  "name": "patchistry-mcp-server",
  "version": "0.2.0",
  "mcpName": "io.github.patchistry/patchistry-mcp-server",
  "description": "MCP (Model Context Protocol) server for Patchistry, a DTC modular hat brand. Exposes 6 tools to AI agents (Claude, ChatGPT, Cursor): list_canvases, list_patches, get_curated_build (bachelorette/wedding/Father's Day/festival), recommend_build via natural language, get_shipping_policy, get_contact.",
